# Vite reads env vars from the REPO ROOT, not from web/ — so this file is
# documentation only. Edit the root .env (or .env.example) instead.
#
# The web app accepts both VITE_* and EXPO_PUBLIC_* keys for Supabase config,
# so the same root .env that the Expo app uses works without duplication.
#
# Local Supabase (default for `supabase start`):
#   VITE_SUPABASE_URL=http://127.0.0.1:54321
#   VITE_SUPABASE_KEY=...           # falls back to EXPO_PUBLIC_SUPABASE_KEY
#
# Auth bypass (defaults to true when unset; set to "false" for real auth):
#   VITE_DEV_SKIP_AUTH=true
