    },
    {
      "name": "Query Patterns (cookbook)",
      "description": "Copy-paste examples of PostgREST features you'll use across tables.",
      "item": [
        {
          "name": "Pagination (Range header)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "apikey", "value": "{{supabase_key}}" },
              { "key": "Range", "value": "0-24" },
              { "key": "Prefer", "value": "count=exact" }
            ],
            "url": {
              "raw": "{{supabase_url}}{{rest_path}}/companies?select=ticker,name&order=ticker.asc",
              "host": ["{{supabase_url}}{{rest_path}}"],
              "path": ["companies"],
              "query": [
                { "key": "select", "value": "ticker,name" },
                { "key": "order", "value": "ticker.asc" }
              ]
            }
          }
        },
        {
          "name": "Embed FK relation",
          "description": "Bring back parent company alongside each director using FK relationship traversal.",
          "request": {
            "method": "GET",
            "header": [{ "key": "apikey", "value": "{{supabase_key}}" }],
            "url": {
              "raw": "{{supabase_url}}{{rest_path}}/directors?select=name,title,companies(ticker,name)&limit=10",
              "host": ["{{supabase_url}}{{rest_path}}"],
              "path": ["directors"],
              "query": [
                { "key": "select", "value": "name,title,companies(ticker,name)" },
                { "key": "limit", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Multiple filters (AND)",
          "request": {
            "method": "GET",
            "header": [{ "key": "apikey", "value": "{{supabase_key}}" }],
            "url": {
              "raw": "{{supabase_url}}{{rest_path}}/executive_compensation?fiscal_year=gte.2022&total_compensation=gte.10000000&select=name,title,fiscal_year,total_compensation,companies(ticker)&order=total_compensation.desc&limit=25",
              "host": ["{{supabase_url}}{{rest_path}}"],
              "path": ["executive_compensation"],
              "query": [
                { "key": "fiscal_year", "value": "gte.2022" },
                { "key": "total_compensation", "value": "gte.10000000" },
                { "key": "select", "value": "name,title,fiscal_year,total_compensation,companies(ticker)" },
                { "key": "order", "value": "total_compensation.desc" },
                { "key": "limit", "value": "25" }
              ]
            }
          }
        },
        {
          "name": "OR filter",
          "request": {
            "method": "GET",
            "header": [{ "key": "apikey", "value": "{{supabase_key}}" }],
            "url": {
              "raw": "{{supabase_url}}{{rest_path}}/companies?or=(ticker.eq.AAPL,ticker.eq.MSFT,ticker.eq.GOOGL)&select=ticker,name",
              "host": ["{{supabase_url}}{{rest_path}}"],
              "path": ["companies"],
              "query": [
                { "key": "or", "value": "(ticker.eq.AAPL,ticker.eq.MSFT,ticker.eq.GOOGL)" },
                { "key": "select", "value": "ticker,name" }
              ]
            }
          }
        },
        {
          "name": "Single object (404 if not exactly one row)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "apikey", "value": "{{supabase_key}}" },
              { "key": "Accept", "value": "application/vnd.pgrst.object+json" }
            ],
            "url": {
              "raw": "{{supabase_url}}{{rest_path}}/companies?ticker=eq.AAPL&select=*",
              "host": ["{{supabase_url}}{{rest_path}}"],
              "path": ["companies"],
              "query": [
                { "key": "ticker", "value": "eq.AAPL" },
                { "key": "select", "value": "*" }
              ]
            }
          }
        },
        {
          "name": "REFERENCE — every query parameter (all disabled, flip on what you need)",
          "description": "Hit Send as-is and you get the full companies table (only `select=*` is enabled). Every other row is a disabled example of a PostgREST query parameter you can enable. Substitute real column names from the table you're targeting.\n\nPostgREST docs: https://postgrest.org/en/stable/references/api/tables_views.html",
          "request": {
            "method": "GET",
            "header": [{ "key": "apikey", "value": "{{supabase_key}}" }],
            "url": {
              "raw": "{{supabase_url}}{{rest_path}}/companies?select=*",
              "host": ["{{supabase_url}}{{rest_path}}"],
              "path": ["companies"],
              "query": [
                { "key": "select", "value": "*", "description": "PROJECTION — return all columns. Default if omitted." },
                { "key": "select", "value": "ticker,name,cik", "disabled": true, "description": "PROJECTION — explicit column list. Cheaper than `*` for wide tables." },
                { "key": "select", "value": "ticker,legal_name:name", "disabled": true, "description": "PROJECTION — alias columns: `output_name:db_column`." },
                { "key": "select", "value": "ticker,cik::text", "disabled": true, "description": "PROJECTION — cast a column to another type using `column::type`." },
                { "key": "select", "value": "raw_data->>field_name", "disabled": true, "description": "PROJECTION — extract jsonb field as text. Use `->` for jsonb subobject, `->>` for text." },
                { "key": "select", "value": "*,directors(*)", "disabled": true, "description": "EMBED — pull the related directors rows for each company via FK relationship." },
                { "key": "select", "value": "*,directors(name,title)", "disabled": true, "description": "EMBED — relation with column projection on the embedded table." },
                { "key": "select", "value": "*,directors!directors_company_id_fkey(*)", "disabled": true, "description": "EMBED — disambiguate which FK to follow when there are multiple FKs between the same two tables." },
                { "key": "select", "value": "*,directors(*),executive_compensation(*)", "disabled": true, "description": "EMBED — multiple relations in one request." },
                { "key": "select", "value": "*,director_count:directors(count)", "disabled": true, "description": "EMBED — return only the count of related rows." },

                { "key": "ticker", "value": "eq.AAPL", "disabled": true, "description": "FILTER eq — equals." },
                { "key": "ticker", "value": "neq.AAPL", "disabled": true, "description": "FILTER neq — not equal." },
                { "key": "cik", "value": "gt.1000000", "disabled": true, "description": "FILTER gt — greater than." },
                { "key": "cik", "value": "gte.1000000", "disabled": true, "description": "FILTER gte — greater than or equal." },
                { "key": "cik", "value": "lt.9999999", "disabled": true, "description": "FILTER lt — less than." },
                { "key": "cik", "value": "lte.9999999", "disabled": true, "description": "FILTER lte — less than or equal." },
                { "key": "name", "value": "like.Apple*", "disabled": true, "description": "FILTER like — SQL LIKE, case-sensitive. `*` is the wildcard (URL-friendly substitute for `%`)." },
                { "key": "name", "value": "ilike.*apple*", "disabled": true, "description": "FILTER ilike — case-insensitive LIKE. Most commonly used for substring search." },
                { "key": "name", "value": "match.^Apple", "disabled": true, "description": "FILTER match — POSIX regex, case-sensitive." },
                { "key": "name", "value": "imatch.^apple", "disabled": true, "description": "FILTER imatch — POSIX regex, case-insensitive." },
                { "key": "ticker", "value": "in.(AAPL,MSFT,GOOGL)", "disabled": true, "description": "FILTER in — value in list. Comma-separated, parens required. Quote strings with commas: `in.(\"a,b\",c)`." },
                { "key": "cik", "value": "is.null", "disabled": true, "description": "FILTER is — IS NULL. Also: `is.true`, `is.false`, `is.unknown`." },
                { "key": "cik", "value": "isdistinct.123", "disabled": true, "description": "FILTER isdistinct — IS DISTINCT FROM (null-safe inequality)." },
                { "key": "name", "value": "fts.iphone", "disabled": true, "description": "FILTER fts — full-text search using `to_tsquery`. Combine words with `&`, `|`, `!`." },
                { "key": "name", "value": "plfts.iphone", "disabled": true, "description": "FILTER plfts — plain full-text search via `plainto_tsquery` (no operator parsing)." },
                { "key": "name", "value": "phfts.apple iphone", "disabled": true, "description": "FILTER phfts — phrase full-text search via `phraseto_tsquery`. Words must appear in order." },
                { "key": "name", "value": "wfts.apple OR iphone", "disabled": true, "description": "FILTER wfts — websearch FTS via `websearch_to_tsquery`. Google-style operators." },
                { "key": "tags", "value": "cs.{apple,tech}", "disabled": true, "description": "FILTER cs — contains. For arrays/jsonb/range. e.g. array contains `{apple,tech}`." },
                { "key": "tags", "value": "cd.{apple,tech,phone}", "disabled": true, "description": "FILTER cd — contained by." },
                { "key": "tags", "value": "ov.{apple,tech}", "disabled": true, "description": "FILTER ov — overlap (any element in common)." },
                { "key": "period", "value": "sl.(2024-01-01,2024-12-31)", "disabled": true, "description": "FILTER sl — strictly left of (range type)." },
                { "key": "period", "value": "sr.(2024-01-01,2024-12-31)", "disabled": true, "description": "FILTER sr — strictly right of." },
                { "key": "period", "value": "nxr.(2024-01-01,2024-12-31)", "disabled": true, "description": "FILTER nxr — does not extend right." },
                { "key": "period", "value": "nxl.(2024-01-01,2024-12-31)", "disabled": true, "description": "FILTER nxl — does not extend left." },
                { "key": "period", "value": "adj.(2024-01-01,2024-12-31)", "disabled": true, "description": "FILTER adj — adjacent to." },

                { "key": "ticker", "value": "not.eq.AAPL", "disabled": true, "description": "NEGATION — prefix any operator with `not.`. Works with ilike, in, is, etc." },
                { "key": "name", "value": "not.ilike.*apple*", "disabled": true, "description": "NEGATION — `not.ilike` excludes substring matches." },

                { "key": "or", "value": "(ticker.eq.AAPL,ticker.eq.MSFT)", "disabled": true, "description": "LOGICAL or — comma-separated conditions inside parens. Equivalent to SQL OR." },
                { "key": "and", "value": "(cik.gt.0,cik.lt.9999999)", "disabled": true, "description": "LOGICAL and — explicit AND group. Multiple top-level params already AND together; this is mainly used inside `or`." },
                { "key": "or", "value": "(name.ilike.*apple*,and(cik.gt.1000,cik.lt.2000))", "disabled": true, "description": "LOGICAL nested — combine `or` with nested `and(...)` for complex predicates." },
                { "key": "or", "value": "(ticker.eq.AAPL,not.and(cik.gt.1000,cik.lt.2000))", "disabled": true, "description": "LOGICAL nested with negation — `not.and(...)` inverts a sub-group." },

                { "key": "order", "value": "name.asc", "disabled": true, "description": "ORDER — ascending by column. `asc` is default; can omit." },
                { "key": "order", "value": "name.desc", "disabled": true, "description": "ORDER — descending." },
                { "key": "order", "value": "name.asc.nullsfirst", "disabled": true, "description": "ORDER — control null placement: `nullsfirst` or `nullslast`." },
                { "key": "order", "value": "cik.desc.nullslast,name.asc", "disabled": true, "description": "ORDER — multi-column, comma-separated. First column is primary sort." },

                { "key": "limit", "value": "25", "disabled": true, "description": "PAGINATION — cap rows returned. Pair with `offset` or use the `Range` header." },
                { "key": "offset", "value": "50", "disabled": true, "description": "PAGINATION — skip N rows. Combine with `limit`." },

                { "key": "directors.order", "value": "name.asc", "disabled": true, "description": "EMBED MODIFIER — order rows inside the embedded `directors(...)` relation." },
                { "key": "directors.limit", "value": "5", "disabled": true, "description": "EMBED MODIFIER — limit rows inside the embedded relation." },
                { "key": "directors.offset", "value": "0", "disabled": true, "description": "EMBED MODIFIER — offset inside the embedded relation." },
                { "key": "directors.title", "value": "eq.CEO", "disabled": true, "description": "EMBED MODIFIER — filter the embedded relation. Format: `<relation>.<col>=<op>.<value>`." },
                { "key": "directors.select", "value": "name,title", "disabled": true, "description": "EMBED MODIFIER — alternate way to project columns on the embedded relation (also can be done inside the select itself)." },

                { "key": "on_conflict", "value": "ticker", "disabled": true, "description": "WRITE-ONLY — for POST upserts: name the unique column to match on. Pair with `Prefer: resolution=merge-duplicates`." },
                { "key": "columns", "value": "ticker,name", "disabled": true, "description": "WRITE-ONLY — for POST: limit which columns are inserted from the body." }
              ]
            }
          }
        },
        {
          "name": "REFERENCE — every header (all disabled, flip on what you need)",
