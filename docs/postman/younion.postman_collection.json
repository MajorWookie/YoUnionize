    {
      "name": "filing_summaries",
      "item": [
        {
          "name": "Latest filing — raw_data only (single object)",
          "description": "Returns just the `raw_data` jsonb of the most recently filed row for the given company. Uses `select=raw_data` to project only that one column, `order=filed_at.desc&limit=1` to take the latest, and the single-object Accept header so the response is the object — not a one-element array.\n\nIf you'd rather sort by DB row creation time, swap `order` to `created_at.desc`. Note the difference: `filed_at` is when SEC received the filing; `created_at` is when our row was inserted (could differ on backfills).\n\nRequires `{{company_id}}` to be set in the environment.",
          "request": {
            "method": "GET",
            "header": [
              { "key": "apikey", "value": "{{supabase_key}}" },
              { "key": "Accept", "value": "application/vnd.pgrst.object+json", "description": "Strip the array wrapper — return the row as an object. 406 if 0 or >1 rows match (limit=1 prevents the >1 case)." }
            ],
            "url": {
              "raw": "{{supabase_url}}{{rest_path}}/filing_summaries?company_id=eq.{{company_id}}&select=raw_data&order=filed_at.desc&limit=1",
              "host": ["{{supabase_url}}{{rest_path}}"],
              "path": ["filing_summaries"],
              "query": [
                { "key": "company_id", "value": "eq.{{company_id}}" },
                { "key": "select", "value": "raw_data", "description": "Project only this column. Massive payload reduction since `raw_data` already is the SEC response — `select=*` would also pull ai_summary, human_summary, etc." },
                { "key": "order", "value": "filed_at.desc", "description": "Most recent SEC filing first. Alt: `created_at.desc` (DB row creation order)." },
                { "key": "limit", "value": "1", "description": "Single row." },
                { "key": "filing_type", "value": "eq.10-K", "disabled": true, "description": "Optional filter — narrow to a specific filing type (e.g. 10-K, 10-Q, 8-K, DEF 14A)." }
              ]
            }
          }
        },
        {
          "name": "Latest filing — raw_data jsonb path (single field inside)",
          "description": "If you only need one field inside the `raw_data` jsonb blob, use the PostgREST jsonb arrow operators in the select. `->` returns jsonb, `->>` returns text. Replace `your_field` with the actual key.",
          "request": {
            "method": "GET",
            "header": [
              { "key": "apikey", "value": "{{supabase_key}}" },
              { "key": "Accept", "value": "application/vnd.pgrst.object+json" }
            ],
            "url": {
              "raw": "{{supabase_url}}{{rest_path}}/filing_summaries?company_id=eq.{{company_id}}&select=value:raw_data->your_field&order=filed_at.desc&limit=1",
              "host": ["{{supabase_url}}{{rest_path}}"],
              "path": ["filing_summaries"],
              "query": [
                { "key": "company_id", "value": "eq.{{company_id}}" },
                { "key": "select", "value": "value:raw_data->your_field", "description": "Pull a sub-field of the raw_data jsonb. Use `->>` instead of `->` if you want it as a plain string rather than nested json. The `value:` prefix renames the column in the response." },
                { "key": "order", "value": "filed_at.desc" },
                { "key": "limit", "value": "1" }
              ]
            }
          }
        },
        {
          "name": "List (limit 25)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "apikey", "value": "{{supabase_key}}" },
              { "key": "Prefer", "value": "count=exact" }
            ],
            "url": {
