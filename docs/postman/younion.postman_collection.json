                { "key": "select", "value": "*" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "user_cost_of_living (RLS — needs user_jwt)",
      "auth": {
        "type": "bearer",
        "bearer": [{ "key": "token", "value": "{{user_jwt}}", "type": "string" }]
      },
      "item": [
        {
          "name": "Mine",
          "request": {
