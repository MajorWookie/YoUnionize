      "description": "Requires authenticated session. Run Auth → Sign in with password first.",
      "auth": {
        "type": "bearer",
        "bearer": [{ "key": "token", "value": "{{user_jwt}}", "type": "string" }]
      },
      "item": [
        {
          "name": "List (limited by RLS to your row)",
          "request": {
            "method": "GET",
            "header": [{ "key": "apikey", "value": "{{supabase_key}}" }],
            "url": {
              "raw": "{{supabase_url}}{{rest_path}}/users?select=*&limit=25",
              "host": ["{{supabase_url}}{{rest_path}}"],
              "path": ["users"],
              "query": [
                { "key": "select", "value": "*" },
                { "key": "limit", "value": "25" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "user_profiles (RLS — needs user_jwt)",
      "auth": {
        "type": "bearer",
        "bearer": [{ "key": "token", "value": "{{user_jwt}}", "type": "string" }]
      },
      "item": [
        {
