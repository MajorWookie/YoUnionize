{
  "expo": {
    "name": "YoUnion",
    "slug": "younion",
    "scheme": "younion",
    "version": "0.1.0",
    "platforms": ["ios", "android", "web"],
    "ios": {
      "bundleIdentifier": "com.majorwookie.younion",
      "supportsTablet": true
    },
    "android": {
      "package": "com.majorwookie.younion"
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
