{
  "name": "younion",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "type": "module",
  "workspaces": [
    "packages/*",
    "app"
  ],
  "packageManager": "bun@1.2.22",
  "scripts": {
    "git-clean": "git rm --cached -r .",
    "sst:dev": "bunx sst dev",
    "sst:deploy": "bunx sst deploy",
    "sst:remove": "bunx sst remove",
    "sst:secrets": "bunx sst secret",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:status": "supabase status",
    "local_supabase:reset": "supabase db reset",
    "remote_supabase:reset": "./scripts/reset-remote.sh",
    "local_supabase:seed": "bun seed",
    "remote_supabase:seed": "bunx dotenvx run -f .env.remote -- bun run seed",
    "supabase:migrate": "supabase db reset",
    "prebuild": "npx expo prebuild",
    "ios": "npx expo run:ios",
    "dev": "supabase start && npx expo start",
    "dev:web": "supabase start && npx expo start --web",
    "dev:functions": "supabase functions serve",
    "build:web": "npx expo export --platform web",
    "deploy:functions": "supabase functions deploy",
    "lint": "oxlint src app packages",
    "lint:fix": "oxfmt src app packages && oxlint --fix --fix-suggestions src app packages",
    "format": "oxfmt src app packages",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:unit": "vitest run",
    "test:e2e": "playwright test --config e2e/playwright.config.ts",
    "test:all": "vitest run && playwright test --config e2e/playwright.config.ts",
    "check:all": "oxlint src app packages && tsc --noEmit; vitest run",
    "android": "npx expo run:android",
    "seed": "bun run scripts/seed-companies.ts",
    "seed:no-ai": "bun run scripts/seed-companies.ts --skip-summarization",
    "review": "bun run scripts/review/index.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.15.5",
    "@supabase/supabase-js": "^2.99.2",
    "@tamagui/config": "^2.0.0-rc.15",
    "@union/ai": "workspace:*",
    "@union/helpers": "workspace:*",
    "@union/hooks": "workspace:*",
    "@union/postgres": "workspace:*",
    "@union/sec-api": "workspace:*",
    "drizzle-orm": "^0.40.0",
    "expo": "~54.0.22",
    "expo-dev-client": "~6.0.20",
    "expo-router": "~6.0.23",
    "expo-updates": "~29.0.16",
    "phosphor-react": "^1.4.1",
    "phosphor-react-native": "^3.0.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-markdown-display": "^7.0.2",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1",
    "react-native-worklets-core": "^1.6.3",
    "tamagui": "^2.0.0-rc.15",
    "valibot": "^1.0.0"
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "^1.40.0",
    "@playwright/test": "^1.50.0",
    "@react-native-community/cli": "^20.1.2",
    "@react-native/babel-preset": "0.81.5",
    "@types/node": "^24.0.0",
    "@types/react": "~19.1.10",
    "@types/react-dom": "~19.1.7",
    "bun-types": "^1.3.10",
    "oxfmt": "^0.16.0",
    "oxlint": "^1.31.0",
    "sst": "^3.17.0",
    "typescript": "^5.9.0",
    "vite": "^7.1.0",
    "vitest": "^3.0.0"
  }
}