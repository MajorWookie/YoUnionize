{
  "name": "union",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": ["packages/*", "app"],
  "scripts": {
    "dev": "one dev",
    "build": "one build",
    "serve": "one serve",
    "lint": "oxlint src app packages",
    "lint:fix": "oxfmt src app packages && oxlint --fix --fix-suggestions src app packages",
    "format": "oxfmt src app packages",
    "test": "vitest",
    "test:unit": "vitest run",
    "test:e2e": "playwright test --config e2e/playwright.config.ts",
    "test:all": "vitest run && playwright test --config e2e/playwright.config.ts",
    "check:all": "oxlint src app packages && tsc --noEmit; vitest run",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:add-migration": "drizzle-kit generate --name",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "sst:deploy": "bunx sst deploy",
    "sst:dev": "bunx sst dev",
    "sst:remove": "bunx sst remove",
    "sst:secrets": "bunx sst secret"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@react-navigation/bottom-tabs": "^7.15.5",
    "@tamagui/config": "^2.0.0-rc.15",
    "@tamagui/vite-plugin": "^2.0.0-rc.15",
    "@union/ai": "workspace:*",
    "@union/helpers": "workspace:*",
    "@union/hooks": "workspace:*",
    "@union/postgres": "workspace:*",
    "@union/sec-api": "workspace:*",
    "@vxrn/color-scheme": "^1.10.6",
    "@vxrn/query-string": "^1.10.6",
    "@vxrn/safe-area": "^1.10.6",
    "@vxrn/url-parse": "^1.10.6",
    "better-auth": "^1.5.5",
    "drizzle-orm": "^0.40.0",
    "one": "^1.9.5",
    "pg": "^8.16.0",
    "phosphor-react": "^1.4.1",
    "phosphor-react-native": "^3.0.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-native": "^0.81.5",
    "react-native-safe-area-context": "^5.4.0",
    "react-native-svg": "^15.15.3",
    "react-native-web": "^0.20.0",
    "rollup": "^4.59.0",
    "tamagui": "^2.0.0-rc.15",
    "valibot": "^1.0.0",
    "vxrn": "^1.10.6"
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "^1.40.0",
    "@types/node": "^24.0.0",
    "@types/pg": "^8.11.0",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.0",
    "bun-types": "^1.3.10",
    "drizzle-kit": "^0.30.0",
    "oxfmt": "^0.16.0",
    "oxlint": "^1.31.0",
    "typescript": "^5.9.0",
    "vite": "^7.1.0",
    "@playwright/test": "^1.50.0",
    "sst": "^3.17.0",
    "vitest": "^3.0.0"
  },
  "packageManager": "bun@1.2.0"
}
