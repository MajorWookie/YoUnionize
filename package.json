{
  "name": "younion",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "web"
  ],
  "packageManager": "bun@1.2.22",
  "scripts": {
    "git-clean": "git rm --cached -r .",
    "sst:dev": "bunx sst dev",
    "sst:deploy": "bunx sst deploy",
    "sst:remove": "bunx sst remove",
    "sst:secrets": "bunx sst secret",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:status": "supabase status",
    "local_supabase:reset": "supabase db reset",
    "remote_supabase:reset": "./scripts/reset-remote.sh",
    "local_supabase:seed": "bun seed",
    "remote_supabase:seed": "bunx dotenvx run -f .env.remote -- bun run seed",
    "supabase:migrate": "supabase db reset",
    "dev": "bunx dotenvx run -f .env.remote -- bun run --cwd web dev",
    "build": "cd web && bun run build",
    "preview": "cd web && bun run preview",
    "dev:functions": "supabase functions serve",
    "deploy:functions": "supabase functions deploy",
    "lint": "oxlint server packages scripts",
    "lint:fix": "oxfmt server packages scripts && oxlint --fix --fix-suggestions server packages scripts",
    "format": "oxfmt server packages scripts",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:unit": "vitest run",
    "test:e2e": "playwright test --config e2e/playwright.config.ts",
    "test:all": "vitest run && playwright test --config e2e/playwright.config.ts",
    "check:all": "oxlint server packages scripts && tsc --noEmit; vitest run",
    "seed": "bun run scripts/seed-companies.ts",
    "seed:no-ai": "bun run scripts/seed-companies.ts --skip-summarization"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@supabase/supabase-js": "^2.99.2",
    "@younionize/ai": "workspace:*",
    "@younionize/api-client": "workspace:*",
    "@younionize/helpers": "workspace:*",
    "@younionize/hooks": "workspace:*",
    "@younionize/postgres": "workspace:*",
    "@younionize/sec-api": "workspace:*",
    "drizzle-orm": "^0.40.0",
    "valibot": "^1.0.0"
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "^1.40.0",
    "@playwright/test": "^1.50.0",
    "@types/node": "^24.0.0",
    "bun-types": "^1.3.10",
    "oxfmt": "^0.16.0",
    "oxlint": "^1.31.0",
    "sst": "^3.17.0",
    "typescript": "^5.9.0",
    "vitest": "^3.0.0"
  }
}
