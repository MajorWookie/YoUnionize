{
  "name": "younionize",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "packageManager": "bun@1.2.22",
  "scripts": {
    "git-clean": "git rm --cached -r .",
    "sst:dev": "bunx sst dev",
    "sst:deploy": "bunx sst deploy",
    "sst:remove": "bunx sst remove",
    "sst:secrets": "bunx sst secret",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:status": "supabase status",
    "local_supabase:reset": "supabase db reset",
    "remote_supabase:reset": "./scripts/reset-remote.sh",
    "local_supabase:seed": "bun seed",
    "remote_supabase:seed": "bunx dotenvx run -f .env.remote -- bun run seed",
    "supabase:migrate": "supabase db reset",
    "dev": "bunx dotenvx run -f .env.remote -- vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "dev:functions": "supabase functions serve",
    "deploy:functions": "supabase functions deploy",
    "lint": "oxlint src server packages scripts",
    "lint:fix": "oxfmt src server packages scripts && oxlint --fix --fix-suggestions src server packages scripts",
    "prompts:generate": "bun run scripts/generate-shared-prompts.ts",
    "prompts:check": "bun run scripts/generate-shared-prompts.ts --check",
    "eval:section": "bunx dotenvx run -f .env.remote -- bun run scripts/eval-section-prompt.ts",
    "format": "oxfmt src server packages scripts",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:unit": "vitest run",
    "test:e2e": "playwright test --config e2e/playwright.config.ts",
    "test:all": "vitest run && playwright test --config e2e/playwright.config.ts",
    "check:all": "oxlint src server packages scripts && tsc --noEmit; vitest run",
    "seed": "bun run scripts/seed-companies.ts",
    "seed:no-ai": "bun run scripts/seed-companies.ts --skip-summarization"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@fontsource-variable/inter": "^5.1.0",
    "@fontsource-variable/source-serif-4": "^5.1.0",
    "@mantine/charts": "^7.15.0",
    "@mantine/core": "^7.15.0",
    "@mantine/form": "^7.15.0",
    "@mantine/hooks": "^7.15.0",
    "@mantine/notifications": "^7.15.0",
    "@supabase/supabase-js": "^2.99.2",
    "@tabler/icons-react": "^3.26.0",
    "@younionize/ai": "workspace:*",
    "@younionize/api-client": "workspace:*",
    "@younionize/helpers": "workspace:*",
    "@younionize/hooks": "workspace:*",
    "@younionize/postgres": "workspace:*",
    "@younionize/sec-api": "workspace:*",
    "drizzle-orm": "^0.40.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-markdown": "^9.0.0",
    "react-router-dom": "^7.1.0",
    "recharts": "^2.15.0",
    "remark-gfm": "^4.0.0",
    "valibot": "^1.0.0"
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "^1.40.0",
    "@playwright/test": "^1.50.0",
    "@types/node": "^24.0.0",
    "@types/react": "~19.1.10",
    "@types/react-dom": "~19.1.7",
    "@vitejs/plugin-react": "^4.3.0",
    "bun-types": "^1.3.10",
    "oxfmt": "^0.16.0",
    "oxlint": "^1.31.0",
    "sst": "^3.17.0",
    "typescript": "^5.9.0",
    "vite": "^7.1.0",
    "vitest": "^3.0.0"
  }
}
