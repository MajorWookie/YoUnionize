# ─────────────────────────────────────────────────────────────────────────────
# Younionize — Environment Variable Template
#
# 1. Copy this file:        cp .env.example .env
# 2. Fill in real values    (your local Supabase keys + your API keys)
# 3. Never commit .env:     it is gitignored — keep it that way.
#
# .env.remote (also gitignored) is used for connecting to a hosted Supabase
# project. Create it the same way if you need to point local dev at staging.
# ─────────────────────────────────────────────────────────────────────────────


# ── Supabase ─────────────────────────────────────────────────────────────────
# For local dev: run `supabase start` and copy the printed keys into here.
# For hosted projects: get keys from the Supabase dashboard → Project Settings → API.
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_KEY=your_supabase_publishable_key_here
SUPABASE_SECRET_KEY=your_supabase_secret_key_here

# Legacy fallbacks — required because some Edge Functions and seed scripts
# still read the older variable names (see CLAUDE.md → Gotchas).
SUPABASE_ANON_KEY=your_supabase_publishable_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_secret_key_here


# ── Client-side (Expo / React Native) ────────────────────────────────────────
# EXPO_PUBLIC_* variables are bundled into the app and visible to clients.
# Only put publishable (non-secret) values here. NEVER the secret/service key.
EXPO_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
EXPO_PUBLIC_SUPABASE_KEY=your_supabase_publishable_key_here


# ── Client-side (Vite — legacy, kept for web compatibility) ──────────────────
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_KEY=your_supabase_publishable_key_here


# ── Database ─────────────────────────────────────────────────────────────────
# Local dev: direct connection on :54322 (used for migrations).
# Hosted dev: copy the pooler URL on :6543 from the Supabase dashboard.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres


# ── SEC API (sec-api.io) ─────────────────────────────────────────────────────
# Sign up: https://sec-api.io/  (free tier available)
SEC_API_KEY=your_sec_api_key_here


# ── Anthropic Claude ─────────────────────────────────────────────────────────
# Sign up: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your_key_here


# ── Voyage AI (embeddings) ───────────────────────────────────────────────────
# Sign up: https://www.voyageai.com/
# Models: voyage-4-lite (dev), voyage-finance-2 (prod) — both 1024-dim.
VOYAGE_API_KEY=pa-your_voyage_key_here
# VOYAGE_EMBEDDING_MODEL=voyage-4-lite


# ── Claude Code MCP servers (optional — only needed if using Claude Code) ────
# Consumed by .mcp.json. Both vars must be exported into your shell (e.g.
# ~/.zshrc) since .env is not auto-sourced for MCP servers.

# Supabase MCP — your project's reference (the subdomain from your Supabase URL,
# e.g. "abcdefghijk" from https://abcdefghijk.supabase.co). Not a credential,
# but parameterized so each contributor points the MCP at their own project.
SUPABASE_PROJECT_REF=your_supabase_project_ref_here

# GitHub MCP — generate at https://github.com/settings/tokens, fine-grained,
# scoped to this repo only.
GITHUB_PERSONAL_ACCESS_TOKEN=github_pat_your_token_here
