# Supabase — server-side
# For local dev, run `supabase start` and copy the keys from the output.
# For hosted Supabase, use your project's publishable + secret keys.
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_KEY=your_supabase_publishable_key_here
SUPABASE_SECRET_KEY=your_supabase_secret_key_here

# Client-side (Expo exposes EXPO_PUBLIC_* to the app bundle)
EXPO_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
EXPO_PUBLIC_SUPABASE_KEY=your_supabase_publishable_key_here

# Client-side (Vite — legacy, kept for web compatibility)
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_KEY=your_supabase_publishable_key_here

# Database (Supabase local Postgres — direct connection for migrations, pooler on :54329 for app)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# SEC API (sec-api.io)
SEC_API_KEY=your_sec_api_key_here

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-your_key_here

# Voyage AI (embeddings — voyage-4-lite for dev, voyage-finance-2 for prod)
VOYAGE_API_KEY=pa-your_voyage_key_here
# VOYAGE_EMBEDDING_MODEL=voyage-4-lite

# GitHub MCP server (consumed by .mcp.json via ${GITHUB_PERSONAL_ACCESS_TOKEN}).
# Generate at https://github.com/settings/tokens — fine-grained, scoped to this repo only.
# Must be exported into your shell (e.g. ~/.zshrc) since .env is not auto-sourced for MCP.
GITHUB_PERSONAL_ACCESS_TOKEN=github_pat_your_token_here
